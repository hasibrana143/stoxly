# Stoxly.ai Backend — Environment Variables
# Copy to .env and fill in real values

# === Core ===
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
DEBUG=false
DATABASE_URL=sqlite:///./stock_platform.db
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,https://stoxly.ai
PORT=8000

# === Auth ===
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5

# === Monitoring ===
SENTRY_DSN=

# === reCAPTCHA ===
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# === Email ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@stoxly.ai

# === AI ===
GEMINI_API_KEY=
ALPHA_VANTAGE_API_KEY=

# === SSL (optional, for local HTTPS) ===
SSL_CERT_PATH=
SSL_KEY_PATH=

# === Demo user (DEBUG only) ===
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# === IP Abuse ===
IP_ABUSE_THRESHOLD=100
IP_ABUSE_WINDOW=60
IP_ABUSE_BLOCK_DURATION=300

# === PostgreSQL (for Docker) ===
POSTGRES_PASSWORD=stoxly_secret
