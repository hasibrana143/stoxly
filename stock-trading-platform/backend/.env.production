# Backend
PORT=8000
DATABASE_URL=postgresql://user:password@host:5432/stoxly
SECRET_KEY=production-secret-key-here
CORS_ORIGINS=https://stoxly.ai,https://www.stoxly.ai
DEBUG=false

# Redis
REDIS_URL=redis://redis:6379/0

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5

# CAPTCHA
RECAPTCHA_SITE_KEY=${RECAPTCHA_SITE_KEY}
RECAPTCHA_SECRET_KEY=${RECAPTCHA_SECRET_KEY}

# Email (SMTP)
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@stoxly.ai

# HTTPS
SSL_CERT_PATH=/etc/ssl/certs/stoxly.crt
SSL_KEY_PATH=/etc/ssl/private/stoxly.key

# APIs
GEMINI_API_KEY=${GEMINI_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}
ALPHA_VANTAGE_API_KEY=${ALPHA_VANTAGE_API_KEY}
SENTRY_DSN=${SENTRY_DSN}
